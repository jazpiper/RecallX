{
  "name": "memforge",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "author": {
    "name": "jazpiper",
    "email": "jazpiper1@gmail.com"
  },
  "main": "dist/server/app/desktop/main.js",
  "bin": {
    "memforge": "./app/cli/bin/pnw.js",
    "pnw": "./app/cli/bin/pnw.js",
    "memforge-mcp": "./app/cli/bin/memforge-mcp.js"
  },
  "description": "Local-first memory workspace with source-run UI, local API, CLI, and MCP tools.",
  "scripts": {
    "dev": "concurrently -n server,renderer -c blue,green \"npm:dev:server\" \"npm:dev:renderer\"",
    "dev:server": "tsx watch app/server/index.ts",
    "dev:mcp": "tsx app/mcp/index.ts",
    "dev:renderer": "vite",
    "dev:renderer:desktop": "MEMFORGE_RENDERER_PORT=5174 MEMFORGE_RENDERER_API_TARGET=http://127.0.0.1:8788 vite",
    "dev:desktop:app": "MEMFORGE_DESKTOP_DEV_URL=http://127.0.0.1:5174 MEMFORGE_DESKTOP_PORT=8788 electron .",
    "dev:desktop": "concurrently -n desktop-renderer,desktop-app -c green,magenta \"npm:dev:renderer:desktop\" \"npm:dev:desktop:app\"",
    "build": "npm run build:server && npm run build:renderer",
    "build:server": "tsc -p tsconfig.server.json",
    "build:renderer": "vite build",
    "desktop": "npm run build && electron .",
    "desktop:run": "MEMFORGE_DESKTOP_PORT=8788 electron .",
    "start:run": "MEMFORGE_PORT=8787 node dist/server/app/server/index.js",
    "start:desktop": "npm run build && concurrently -n server,desktop -c blue,magenta \"npm:start:run\" \"npm:desktop:run\"",
    "mcp": "node dist/server/app/mcp/index.js",
    "prepare:cli-package": "node scripts/prepare-cli-package.mjs",
    "verify:cli-package": "node scripts/verify-cli-package.mjs",
    "pack:cli": "npm run build && npm run prepare:cli-package && npm pack ./release/npm-cli",
    "publish:cli": "npm run build && npm run prepare:cli-package && npm publish ./release/npm-cli --provenance",
    "start": "node dist/server/app/server/index.js",
    "test": "vitest run",
    "check": "tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.renderer.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "graphology": "^0.26.0",
    "graphology-layout": "^0.6.1",
    "mime-types": "^2.1.35",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sigma": "^3.0.2",
    "sqlite-vec": "^0.1.7",
    "ulid": "^2.3.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/mime-types": "^2.1.4",
    "@types/node": "^22.13.10",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^36.9.5",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vite": "^6.2.2",
    "vitest": "^3.0.8"
  }
}
