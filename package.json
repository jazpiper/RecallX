{
  "name": "recallx",
  "version": "1.3.1",
  "private": true,
  "type": "module",
  "author": {
    "name": "jazpiper",
    "email": "jazpiper1@gmail.com"
  },
  "license": "MIT",
  "engines": {
    "node": ">=22.13.0"
  },
  "main": "dist/server/app/server/index.js",
  "bin": {
    "recallx": "./app/cli/bin/recallx.js",
    "recallx-mcp": "./app/cli/bin/recallx-mcp.js"
  },
  "description": "Local-first memory workspace with source-run UI, local API, CLI, and MCP tools.",
  "scripts": {
    "changeset": "changeset",
    "changeset:status": "changeset status --verbose",
    "dev": "concurrently -n server,renderer -c blue,green \"npm:dev:server\" \"npm:dev:renderer\"",
    "dev:server": "tsx watch app/server/index.ts",
    "dev:mcp": "tsx app/mcp/index.ts",
    "dev:renderer": "vite",
    "build": "npm run build:server && npm run build:renderer",
    "build:server": "tsc -p tsconfig.server.json",
    "build:renderer": "vite build",
    "start:run": "RECALLX_PORT=8787 node dist/server/app/server/index.js",
    "mcp": "node dist/server/app/mcp/index.js",
    "prepare:full-package": "node scripts/prepare-package.mjs full",
    "prepare:headless-package": "node scripts/prepare-package.mjs headless",
    "branch:check": "node scripts/check-branch-hygiene.mjs",
    "branch:new": "node scripts/create-task-worktree.mjs",
    "version:check": "node scripts/check-version-hygiene.mjs",
    "version:bump": "node scripts/bump-version.mjs",
    "release:verify": "npm run check && npm test && npm run build && npm run prepare:full-package && npm run prepare:headless-package && npm run verify:full-package && npm run verify:headless-package",
    "release:publish": "node scripts/publish-release-packages.mjs",
    "verify:full-package": "node scripts/verify-package.mjs full",
    "verify:headless-package": "node scripts/verify-package.mjs headless",
    "version:release": "changeset version && node scripts/sync-package-versions.mjs",
    "pack:full": "npm run build && npm run prepare:full-package && npm pack ./release/npm-recallx",
    "pack:headless": "npm run build && npm run prepare:headless-package && npm pack ./release/npm-headless",
    "publish:full": "npm run build && npm run prepare:full-package && npm publish ./release/npm-recallx --provenance",
    "publish:headless": "npm run build && npm run prepare:headless-package && npm publish ./release/npm-headless --provenance",
    "start": "node dist/server/app/server/index.js",
    "test": "vitest run",
    "check": "tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.renderer.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "graphology": "^0.26.0",
    "graphology-layout": "^0.6.1",
    "mime-types": "^2.1.35",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sigma": "^3.0.2",
    "sqlite-vec": "^0.1.7",
    "ulid": "^2.3.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/mime-types": "^2.1.4",
    "@types/node": "^22.13.10",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vite": "^6.2.2",
    "vitest": "^3.0.8"
  }
}
